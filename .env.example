# =============================================================================
# Kaleidoscope — Environment Variables
# Copy this file to .env and fill in your values.


# Local dev: JWT_SECRET_KEY and ADMIN_API_KEY have dev defaults in docker-compose.yml
#            and do not need to be set here for local development.
# Production: You MUST set JWT_SECRET_KEY and ADMIN_API_KEY to strong random values.
#             Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# =============================================================================
# BACKEND
# =============================================================================

# API Settings
API_TITLE=Kaleidoscope API
API_VERSION=1.0.0

# Authentication

# Local dev defaults: JWT_SECRET_KEY=dev-jwt-secret, ADMIN_API_KEY=dev-admin-key
# Override here for production with strong random values.
JWT_SECRET_KEY=dev-jwt-secret
ADMIN_API_KEY=dev-admin-key

# Optional extension connectors (comma-separated, e.g. aibots)
KALEIDOSCOPE_EXTENSIONS=

# Logging (set to DEBUG to see per-call LLM details)
LOG_LEVEL=INFO

# Database
# Docker: postgresql://kaleidoscope:kaleidoscope_dev_password@db:5432/kaleidoscope
# Local:  postgresql://user:password@localhost:5432/kaleidoscope
DATABASE_URL=postgresql://kaleidoscope:kaleidoscope_dev_password@localhost:5432/kaleidoscope
DATABASE_ECHO=False

# LLM Providers (add keys for providers you want to use)
# DEFAULT_LLM_MODEL defaults to gemini/gemini-2.5-flash-lite (see backend/src/common/config.py)
# DEFAULT_LLM_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AZURE_API_KEY=your_azure_api_key_here
AZURE_API_BASE=your_azure_endpoint_here
LITELLM_PROXY_API_KEY=your_litellm_proxy_api_key_here
LITELLM_PROXY_API_BASE=your_litellm_proxy_endpoint_here

# Web Search (Serper API for contextual question generation)
SERPER_API_KEY=your_serper_api_key_here

# Langfuse Observability (optional)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_BASE_URL=https://your-langfuse-instance.example.com

# Generation Defaults
DEFAULT_PERSONA_COUNT=5
DEFAULT_QUESTION_COUNT=10

# =============================================================================
# FRONTEND
# =============================================================================

# Backend API URL
# Docker: http://localhost:8000
# Local:  http://localhost:8000
NEXT_PUBLIC_API_DOMAIN=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
