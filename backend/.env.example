# API Settings
API_TITLE=Kaleidoscope API
API_VERSION=1.0.0

# Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here
ADMIN_API_KEY=your_admin_api_key_here

# Optional extension connectors, e.g. aibots
KALEIDOSCOPE_EXTENSIONS=

# Logging (set to DEBUG to see per-call LLM details)
LOG_LEVEL=INFO

# Database
# For Docker: postgresql://kaleidoscope:kaleidoscope_dev_password@db:5432/kaleidoscope
# For local: postgresql://user:password@localhost:5432/kaleidoscope
DATABASE_URL=postgresql://kaleidoscope:kaleidoscope_dev_password@localhost:5432/kaleidoscope
DATABASE_ECHO=False

# LLM Settings
# DEFAULT_LLM_MODEL is optional - defaults to gemini/gemini-2.5-flash-lite (defined in src/common/config.py)
# Uncomment to override: DEFAULT_LLM_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AZURE_API_KEY=your_azure_api_key_here
AZURE_API_BASE=your_azure_endpoint_here
LITELLM_PROXY_API_KEY=your_litellm_proxy_api_key_here
LITELLM_PROXY_API_BASE=your_litellm_proxy_endpoint_here

# Web Search (Serper API for contextual question generation)
SERPER_API_KEY=your_serper_api_key_here

# Langfuse Observability (optional)
LANGFUSE_SECRET_KEY=sk-lf-                                                                                                                    
LANGFUSE_PUBLIC_KEY=pk-lf-                                                                                                                    
LANGFUSE_BASE_URL=https://langfuse.ai-optimisation.site

# Generation Defaults
DEFAULT_PERSONA_COUNT=5
DEFAULT_QUESTION_COUNT=10
