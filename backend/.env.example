# API Settings
API_TITLE=Kaleidoscope API
API_VERSION=1.0.0

# Database
# For Docker: postgresql://kaleidoscope:kaleidoscope_dev_password@db:5432/kaleidoscope
# For local: postgresql://user:password@localhost:5432/kaleidoscope
DATABASE_URL=postgresql://kaleidoscope:kaleidoscope_dev_password@localhost:5432/kaleidoscope
DATABASE_ECHO=False

# LLM Settings
# DEFAULT_LLM_MODEL is optional - defaults to gemini/gemini-2.0-flash (defined in src/common/config.py)
# Uncomment to override: DEFAULT_LLM_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Phoenix Observability (optional)
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# PHOENIX_API_KEY=your_phoenix_api_key_here

# Generation Defaults
DEFAULT_PERSONA_COUNT=5
DEFAULT_QUESTION_COUNT=10
