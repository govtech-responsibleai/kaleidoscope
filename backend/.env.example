# =============================================================================
# Kaleidoscope — Environment Variables
# Copy this file to .env and fill in your values.


# Local dev: JWT_SECRET_KEY and ADMIN_API_KEY have dev defaults in docker-compose.yml
#            and do not need to be set here for local development.
# Production: You MUST set JWT_SECRET_KEY and ADMIN_API_KEY to strong random values.
#             Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# API Settings
API_TITLE=Kaleidoscope API
API_VERSION=1.0.0

# Authentication

# Local dev defaults: JWT_SECRET_KEY=dev-jwt-secret, ADMIN_API_KEY=dev-admin-key
# Override here for production with strong random values.
JWT_SECRET_KEY=dev-jwt-secret
ADMIN_API_KEY=dev-admin-key

# Google Sign-In (optional)
# GOOGLE_CLIENT_ID is the OAuth 2.0 Client ID from Google Cloud Console.
# ALLOWED_EMAIL_DOMAINS is exact-match only; gov.sg does not include agency.gov.sg.
# Leave ALLOWED_EMAIL_DOMAINS empty to reject all Google sign-ins.
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# ALLOWED_EMAIL_DOMAINS=gov.sg,tech.gov.sg

# Self-signup whitelist (optional)
# SIGNUP_WHITELIST_PATH points to an editable plain-text file, one email per line
# (blank lines and lines starting with # are ignored). Emails in this file may
# self-register via POST /auth/signup. Edits take effect immediately (read per request).
# If the file is missing, self-registration is disabled (fail closed).
# SIGNUP_WHITELIST_PATH=backend/signup_whitelist.txt

# Demo target seeding (optional; enabled only when DEMO_TARGET_ENDPOINT is set)
# New Google-auth users receive this HTTP target automatically on first sign-in.
DEMO_TARGET_NAME=Demo Chatbot
DEMO_TARGET_AGENCY=GovTech Singapore
DEMO_TARGET_PURPOSE=A short description of what this demo chatbot helps users do.
DEMO_TARGET_TARGET_USERS=Describe the intended users for this demo chatbot.
DEMO_TARGET_ENDPOINT=https://example.com/chat
DEMO_TARGET_RESPONSE_PATH=answer
DEMO_TARGET_RETRIEVED_CONTEXT_PATH=sources
# Put the real API key only in a private .env file or deployment secret manager.
DEMO_TARGET_HEADERS={"Content-Type":"application/json","X-API-Key":"<secret-from-private-env>"}
DEMO_TARGET_BODY_TEMPLATE={"question":"{{prompt}}"}

# Optional extension connectors (comma-separated, e.g. aibots)
KALEIDOSCOPE_EXTENSIONS=

# Admin seed — creates an admin user on first startup if both set and user doesn't exist.
# Idempotent: does nothing if the user already exists. Change password via API afterwards.
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=change-me

# Logging (set to DEBUG to see per-call LLM details)
LOG_LEVEL=INFO

# Database
# Docker: postgresql://kaleidoscope:kaleidoscope_dev_password@db:5432/kaleidoscope
# Local:  postgresql://user:password@localhost:5432/kaleidoscope
DATABASE_URL=postgresql://kaleidoscope:kaleidoscope_dev_password@localhost:5432/kaleidoscope
DATABASE_ECHO=False

# LLM Providers (add keys for providers you want to use)
# DEFAULT_LLM_MODEL defaults to gemini/gemini-2.5-flash-lite (see backend/src/common/config.py)
# DEFAULT_LLM_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AZURE_API_KEY=your_azure_api_key_here
AZURE_API_BASE=your_azure_endpoint_here
LITELLM_PROXY_API_KEY=your_litellm_proxy_api_key_here
LITELLM_PROXY_API_BASE=your_litellm_proxy_endpoint_here

# Web Search (Serper API for contextual question generation)
SERPER_API_KEY=your_serper_api_key_here

# Langfuse Observability (optional)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_BASE_URL=https://your-langfuse-instance.example.com

# Nemotron Personas Dataset (optional — defaults to Singapore)
# Set to any nvidia/Nemotron-Personas-* HuggingFace dataset.
# Known countries: Singapore (default), USA, India, Japan, Korea, France, Brazil.
# See README.md → "Customising personas" for details.
# NEMOTRON_PERSONAS_DATASET=nvidia/Nemotron-Personas-Singapore

# Generation Defaults
DEFAULT_PERSONA_COUNT=5
DEFAULT_QUESTION_COUNT=10
